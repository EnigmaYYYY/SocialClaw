# =====================================================
# SocialClaw Environment Configuration Template
# =====================================================
#
# SETUP:
#   cp .env.example .env
#   # Fill in your actual values below
#
# SECURITY:
#   - Never commit .env to version control
#   - Each team member should use their own API keys
#   - .env is already in .gitignore
# =====================================================


# ===================
# Social Copilot - Visual Monitor & Assistant
# ===================

# Visual Monitor API
SOCIAL_COPILOT_VISUAL_MONITOR_API_BASE_URL=http://127.0.0.1:18777
SOCIAL_COPILOT_VISUAL_MONITOR_STRATEGY=hybrid
SOCIAL_COPILOT_VISUAL_MONITOR_OCR_MODE=hybrid

# Assistant (reply suggestion model)
SOCIAL_COPILOT_ASSISTANT_ENABLED=true
# If empty, falls back to LLM_BASE_URL
SOCIAL_COPILOT_ASSISTANT_BASE_URL=https://your-llm-proxy.example.com/v1
SOCIAL_COPILOT_ASSISTANT_API_KEY=sk-your-assistant-api-key
SOCIAL_COPILOT_ASSISTANT_MODEL=your-model-name
SOCIAL_COPILOT_ASSISTANT_TIMEOUT_MS=12000
SOCIAL_COPILOT_ASSISTANT_TEMPERATURE=0.4
SOCIAL_COPILOT_ASSISTANT_MAX_TOKENS=800
SOCIAL_COPILOT_ASSISTANT_SUGGESTION_COUNT=3
SOCIAL_COPILOT_ASSISTANT_MAX_MESSAGES=24

# VLM (vision language model for screenshot recognition)
SOCIAL_COPILOT_VLM_ENABLED=true
SOCIAL_COPILOT_VISION_BASE_URL=https://your-vlm-provider.example.com/v1
SOCIAL_COPILOT_VISION_API_KEY=sk-your-vlm-api-key
SOCIAL_COPILOT_VISION_MODEL=your-vlm-model-name
SOCIAL_COPILOT_VLM_TIMEOUT_MS=30000
SOCIAL_COPILOT_VLM_TEMPERATURE=0.0
SOCIAL_COPILOT_VLM_MAX_TOKENS=800

# EverMemOS Integration
SOCIAL_COPILOT_EVERMEMOS_ENABLED=true
SOCIAL_COPILOT_EVERMEMOS_API_BASE_URL=http://127.0.0.1:1995
SOCIAL_COPILOT_EVERMEMOS_REQUEST_TIMEOUT_MS=12000
SOCIAL_COPILOT_OWNER_ID=self

# EverMemOS Reply Suggestion URL (optional)
# If set, Visual Monitor will forward suggestion requests to EverMemOS
# If not set, Visual Monitor uses its local SocialReplyAssistant
# EVERMEMOS_REPLY_URL=http://127.0.0.1:1995/api/v1/copilot/reply-suggestion


# ===================
# LLM Configuration (EverMemOS memory pipeline)
# ===================

LLM_PROVIDER=openai
LLM_BASE_URL=https://your-llm-proxy.example.com/v1
LLM_API_KEY=sk-your-llm-api-key
LLM_MODEL=your-model-name
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=32768
# LLM global concurrency limit (prevents 429 rate limiting)
LLM_MAX_CONCURRENT=5
# OpenRouter provider routing (optional)
# LLM_OPENROUTER_PROVIDER=cerebras
# LLM_EXTRA_BODY={"key": "value"}
# LLM_THINKING_BUDGET=0


# ===================
# Vectorize / Embedding Service
# ===================

VECTORIZE_PROVIDER=vllm
VECTORIZE_BASE_URL=http://127.0.0.1:11434/v1
VECTORIZE_MODEL=nomic-embed-text
VECTORIZE_API_KEY=ollama
# MUST be 768 for nomic-embed-text, mismatch causes DB errors
VECTORIZE_DIMENSIONS=768
VECTORIZE_TIMEOUT=30
VECTORIZE_MAX_RETRIES=3
VECTORIZE_BATCH_SIZE=10
VECTORIZE_MAX_CONCURRENT=5
VECTORIZE_ENCODING_FORMAT=float


# ===================
# Rerank Service
# ===================

RERANK_PROVIDER=siliconflow
RERANK_API_KEY=sk-your-rerank-api-key
RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TIMEOUT=30
RERANK_MAX_RETRIES=3
RERANK_BATCH_SIZE=10
RERANK_MAX_CONCURRENT=5


# ===================
# Redis
# ===================

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=8
REDIS_SSL=false


# ===================
# MongoDB
# ===================

MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=changeme
MONGODB_DATABASE=memsys
MONGODB_URI_PARAMS=socketTimeoutMS=15000&authSource=admin


# ===================
# Elasticsearch
# ===================

ES_HOSTS=http://127.0.0.1:19200
ES_USERNAME=
ES_PASSWORD=
ES_VERIFY_CERTS=false
SELF_ES_INDEX_NS=memsys


# ===================
# Milvus (Vector DB)
# ===================

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
SELF_MILVUS_COLLECTION_NS=memsys


# ===================
# API Server
# ===================

API_BASE_URL=http://127.0.0.1:1995


# ===================
# Environment & Logging
# ===================

LOG_LEVEL=INFO
ENV=dev
PYTHONASYNCIODEBUG=1
MEMORY_LANGUAGE=en
