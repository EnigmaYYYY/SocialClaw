{
  "name": "@enigmayyy/socialclaw",
  "version": "1.0.0",
  "description": "CLI launcher for the SocialClaw desktop stack",
  "keywords": [
    "socialclaw",
    "social-copilot",
    "electron",
    "cli",
    "desktop-ai"
  ],
  "homepage": "https://github.com/EnigmaYYYY/SocialClaw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EnigmaYYYY/SocialClaw.git"
  },
  "bugs": {
    "url": "https://github.com/EnigmaYYYY/SocialClaw/issues"
  },
  "bin": {
    "socialclaw": "./bin/socialclaw.js"
  },
